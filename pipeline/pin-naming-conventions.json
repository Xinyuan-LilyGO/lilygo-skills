{
  "schema_version": 1,
  "note": "Naming-convention table for auto-mapping official #define macros to canonical fact keys. A manifest source with \"auto_pins\": true needs no per-pin mapping: the extractor scans every #define in the block, normalizes the macro name (strip these prefixes/suffixes), and maps it via this table. Macros not in the table are skipped, never guessed. The equivalence gate (verify-auto-mapping.js) proves this table reproduces the hand-authored mappings for T-Beam and T-Deck.",
  "strip_prefixes": ["BOARD_"],
  "strip_suffixes": ["_PIN"],
  "macro_to_key": {
    "I2C_SDA": "pin.i2c.sda",
    "I2C_SCL": "pin.i2c.scl",
    "GPS_RX": "pin.gps.rx",
    "GPS_TX": "pin.gps.tx",
    "RADIO_SCLK": "pin.lora.sclk",
    "RADIO_MISO": "pin.lora.miso",
    "RADIO_MOSI": "pin.lora.mosi",
    "RADIO_CS": "pin.lora.cs",
    "RADIO_RST": "pin.lora.rst",
    "RADIO_DIO0": "pin.lora.dio0",
    "RADIO_DIO1": "pin.lora.dio1",
    "RADIO_BUSY": "pin.lora.busy",
    "POWERON": "pin.power.on",
    "TOUCH_INT": "pin.touch.int",
    "KEYBOARD_INT": "pin.keyboard.int",
    "SDCARD_CS": "pin.sdcard.cs",
    "TFT_CS": "pin.display.cs",
    "TFT_DC": "pin.display.dc",
    "TFT_BACKLIGHT": "pin.display.backlight",
    "SPI_SCK": "pin.spi.sck",
    "SPI_MOSI": "pin.spi.mosi",
    "SPI_MISO": "pin.spi.miso",
    "PIN_LCD_D0": "pin.display.d0",
    "PIN_LCD_D1": "pin.display.d1",
    "PIN_LCD_D2": "pin.display.d2",
    "PIN_LCD_D3": "pin.display.d3",
    "PIN_LCD_D4": "pin.display.d4",
    "PIN_LCD_D5": "pin.display.d5",
    "PIN_LCD_D6": "pin.display.d6",
    "PIN_LCD_D7": "pin.display.d7",
    "PIN_LCD_BL": "pin.display.backlight",
    "PIN_LCD_CS": "pin.display.cs",
    "PIN_LCD_DC": "pin.display.dc",
    "PIN_LCD_RES": "pin.display.reset",
    "PIN_LCD_WR": "pin.display.wr",
    "PIN_LCD_RD": "pin.display.rd",
    "PIN_POWER_ON": "pin.power.on"
  }
